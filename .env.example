# Copy to .env for local runs (never commit secrets)

FILES_USER=admin
FILES_PASSWORD=changeme-dev-password

# Up to 5 MCP bearer keys (comma-separated) or MCPHOSTING_MCP_KEY_1 … _5
MCPHOSTING_MCP_KEYS=mch_mcp_live_dev_key_one,mch_mcp_live_dev_key_two

# Optional denylist of tool names
# MCPHOSTING_MCP_TOOLS_DENY=

MCPHOSTING_PUBLIC_BASE_URL=http://localhost:8088
