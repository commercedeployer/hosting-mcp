# hosting-mcp — пример env (секреты не коммитить)

# Filebrowser
FILES_USER=admin
FILES_PASSWORD=changeme-dev-password-min-12

# MCP (до 5 ключей)
HOSTINGMCP_MCP_KEYS=mch_mcp_live_dev_key_one,mch_mcp_live_dev_key_two

# URL сайта (в проде часто выставляет entrypoint из FREE/CUSTOM)
HOSTINGMCP_PUBLIC_BASE_URL=http://localhost:8088

# Квоты (остальное — дефолты в образе)
# HOSTINGMCP_MAX_STORAGE_MB=1024
# HOSTINGMCP_MCP_MAX_UPLOAD_MB=25
